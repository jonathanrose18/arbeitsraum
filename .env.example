POSTGRES_HOST=localhost
# POSTGRES_PORT is only used for the local dev host port mapping (docker-compose.dev.yml).
# Docker inter-container networking always uses the container's internal port (5432).
POSTGRES_PORT=5432
POSTGRES_DB=arbeitsraum
POSTGRES_USER=arbeitsraum
POSTGRES_PASSWORD=arbeitsraum

# Used for local development. In Docker, DATABASE_URL is constructed from the vars above.
DATABASE_URL="postgresql://arbeitsraum:arbeitsraum@localhost:5432/arbeitsraum"

# Next.js app port
PORT=3000

# Better Auth — REQUIRED. Generate with: openssl rand -base64 32
# setup.sh will auto-generate this for you.
BETTER_AUTH_SECRET=

# Set this to the URL where the app will be publicly accessible.
# Local dev: http://localhost:3000
# Self-hosted (Coolify, Dokku, etc.): https://yourdomain.com
# This is set by the deployer — there is no universal default.
BETTER_AUTH_URL=http://localhost:3000
